# Python/runtime noise
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Local app/runtime state
archive_config.local.json
*.log

# Locally supplied integration bundles and generated test artifacts.
*.zip
test_crawl_and_reassemble/**/system/packages/
test_crawl_and_reassemble/**/input/*
!test_crawl_and_reassemble/**/input/.gitkeep
test_crawl_and_reassemble/**/intermediate/*
!test_crawl_and_reassemble/**/intermediate/.gitkeep
test_crawl_and_reassemble/**/logs/*
!test_crawl_and_reassemble/**/logs/.gitkeep
test_crawl_and_reassemble/**/output/*
!test_crawl_and_reassemble/**/output/.gitkeep

# Downloaded exam artifacts are intentionally not versioned.
# Keep the folder shape, not the downloaded PDFs/images/docs.
downloads/*
!downloads/.gitkeep
!downloads/README.md
official_downloads/*
!official_downloads/.gitkeep
!official_downloads/README.md
exports/*
!exports/.gitkeep
!exports/README.md

# Generated reports can contain local paths and large inventories.
reports/*
!reports/README.md
!reports/summary.json
